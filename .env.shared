#!/usr/bin/env bash
# ============================================================
# LinkedEye Shared Infrastructure — Master Variables File
# Source this BEFORE running any script: source .env.shared
# ============================================================

# ─── AWS ACCOUNT ────────────────────────────────────────────
export AWS_ACCOUNT_ID="654697417727"
export AWS_REGION="ap-south-1"

# ─── PROJECT IDENTIFIERS ────────────────────────────────────
export PROJECT="linkedeye"
export ENVIRONMENT="prod"
export CLUSTER_NAME="le-shared-k8s"

# ─── NETWORK CIDRs ──────────────────────────────────────────
export VPC_CIDR="10.15.0.0/16"
export PUBLIC_SUBNET_AZ1_CIDR="10.15.1.0/24"
export PUBLIC_SUBNET_AZ2_CIDR="10.15.2.0/24"
export PRIVATE_SUBNET_AZ1_CIDR="10.15.10.0/24"
export PRIVATE_SUBNET_AZ2_CIDR="10.15.11.0/24"
export STORAGE_SUBNET_AZ1_CIDR="10.15.20.0/24"
export STORAGE_SUBNET_AZ2_CIDR="10.15.21.0/24"
export ONPREM_CIDR="10.15.0.0/24"

# ─── AVAILABILITY ZONES ─────────────────────────────────────
export AZ1="ap-south-1a"
export AZ2="ap-south-1b"
export AZ3="ap-south-1c"

# ─── EC2 CONFIGURATION ──────────────────────────────────────
export MASTER_INSTANCE_TYPE="m5.2xlarge"     # 8 vCPU, 32 GB
export WORKER_INSTANCE_TYPE="m5.4xlarge"     # 16 vCPU, 64 GB
export BASTION_INSTANCE_TYPE="t3.medium"     # 2 vCPU, 4 GB
export AMI_ID="ami-0f58b397bc5c1f2e8"        # Ubuntu 22.04 LTS ap-south-1
export KEY_PAIR_NAME="le-shared-k8s-key"

# ─── KUBERNETES ─────────────────────────────────────────────
export K8S_VERSION="1.29"
export POD_CIDR="192.168.0.0/16"             # Calico (no overlap with VPC)
export SERVICE_CIDR="172.20.0.0/16"
export K8S_MASTER_PRIVATE_IP="10.15.10.10"

# ─── ON-PREM VPN ────────────────────────────────────────────
export ONPREM_BGP_ASN="65000"
export AWS_BGP_ASN="64512"
export FORTIGATE_PUBLIC_IP="<YOUR_FORTIGATE_PUBLIC_IP>"   # Replace before running

# ─── DOMAIN NAMES ───────────────────────────────────────────
export BASE_DOMAIN="linkedeye.internal"
export JENKINS_DOMAIN="jenkins.finspot.in"
export ARGOCD_DOMAIN="argocd.finspot.in"
export HARBOR_DOMAIN="harbor.finspot.in"
export KEYCLOAK_DOMAIN="keycloak.finspot.in"
export VAULT_DOMAIN="vault.finspot.in"
export REDMINE_DOMAIN="redmine.finspot.in"
export ITSM_DOMAIN="fs-le-dev-inc.finspot.in"

# ─── EKS CLUSTER (Hybrid Nodes — control plane on AWS, workers on-prem) ──
export EKS_CLUSTER_NAME="linkedeye-finspot-k8s-cluster"
export EKS_K8S_VERSION="1.31"

# ─── MANAGEMENT EC2s (PUBLIC subnet — no bastion needed) ──
export JENKINS_EC2_TYPE="m5.xlarge"         # 4 vCPU, 16 GB
export MGMT_EC2_TYPE="m5.2xlarge"           # 8 vCPU, 32 GB (Mgmt tools + ITSM)

# ─── EKS SUBNETS (for control plane ENIs) ─────────────────
# These are set dynamically from /tmp/le-network-ids.env
# Using private subnets AZ1 + AZ2 for EKS control plane
export EKS_SUBNET_AZ1B="${PRIV_SUBNET_AZ1:-subnet-PLACEHOLDER}"
export EKS_SUBNET_AZ1C="${PRIV_SUBNET_AZ2:-subnet-PLACEHOLDER}"

# ─── HYBRID NODES (on-prem worker per client) ─────────────
export HYBRID_NODE_ROLE_NAME="${PROJECT}-eks-hybrid-node-role"
export HYBRID_ACTIVATION_NAME="${PROJECT}-hybrid-activation"

# ─── ENTERPRISE HARDENING ──────────────────────────────────
export KMS_EKS_ALIAS="${PROJECT}-kms-eks"
export KMS_VAULT_ALIAS="${PROJECT}-kms-vault"
export KMS_EBS_ALIAS="${PROJECT}-kms-ebs"
export WAF_WEB_ACL_NAME="${PROJECT}-waf-acl"
export VELERO_BUCKET="${PROJECT}-velero-backups-${AWS_ACCOUNT_ID}"
export GRAFANA_DOMAIN="grafana.finspot.in"

# ─── TAGS ───────────────────────────────────────────────────
export TAG_PROJECT="LinkedEye"
export TAG_OWNER="FinSpot-Technology-Solutions"
export TAG_ENV="Production"
export COMMON_TAGS="Key=Project,Value=${TAG_PROJECT} Key=Environment,Value=${TAG_ENV} Key=Owner,Value=${TAG_OWNER} Key=ManagedBy,Value=aws-cli"

echo "[OK] Environment variables loaded for LinkedEye (${AWS_REGION})"
